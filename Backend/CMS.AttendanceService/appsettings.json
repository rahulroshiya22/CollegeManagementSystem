{
    "AllowedHosts": "*",
    "ConnectionStrings": {
        "DefaultConnection": "Host=aws-1-ap-south-1.pooler.supabase.com;Port=6543;Database=postgres;Username=postgres.hiklcaqunqdtionxtpgi;Password=fK9JDiEUlLJZFiMo;SSL Mode=Require;Trust Server Certificate=true;Pooling=false;Keepalive=30;CommandTimeout=60"
    },
    "Serilog": {
        "Using": [
            "Serilog.Sinks.Console" ],
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Warning",
                "System": "Warning",
                "Microsoft.Hosting.Lifetime": "Information"
            }
        },
        "Enrich": [
            "FromLogContext",
            "WithMachineName",
            "WithThreadId"
        ],
        "WriteTo": [
            {
                "Name": "Console",
                "Args": {
                    "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {TraceId} {Message:lj}{NewLine}{Exception}"
                }
            },
            {
                "Name": "File",
                "Args": {
                    "path": "logs/attendanceservice-.txt",
                    "rollingInterval": "Day",
                    "retainedFileCountLimit": 7,
                    "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff} [{Level:u3}] {TraceId} {Message:lj}{NewLine}{Exception}"
                }
            },
            {
                "Name": "Seq",
                "Args": {
                    "serverUrl": "http://localhost:5341"
                }
            }
        ],
        "Properties": {
            "Application": "CMS.AttendanceService"
        }
    },
    "Jwt": {
        "SecretKey": "YourSuperSecretKeyForJWTTokenGeneration12345!",
        "Issuer": "CMS.AuthService",
        "Audience": "CMS.Client"
    }
}